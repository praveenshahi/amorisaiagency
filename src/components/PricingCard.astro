---
export interface Props {
  setupINR: string;
  retainerINR: string;
  setupUSD: string;
  retainerUSD: string;
  note?: string;
}
const { setupINR, retainerINR, setupUSD, retainerUSD, note } = Astro.props;
---
<div class="pricing-card card" style="background:var(--surface2);">
  <div class="section-label">Pricing</div>
  <div class="pricing-row">
    <div>
      <div style="font-family:'DM Mono',monospace; font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;">Setup</div>
      <div class="price-inr"><span class="price-amount">{setupINR}</span></div>
      <div class="price-usd"><span class="price-amount">{setupUSD}</span></div>
    </div>
    <div class="pricing-divider">+</div>
    <div>
      <div style="font-family:'DM Mono',monospace; font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;">Monthly retainer</div>
      <div class="price-inr"><span class="price-amount">{retainerINR}</span></div>
      <div class="price-usd"><span class="price-amount">{retainerUSD}</span></div>
    </div>
  </div>
  {note && <p style="font-size:13px; margin-top:16px; color:var(--text-muted);">{note}</p>}
  <div style="margin-top:20px; display:flex; gap:12px;">
    <a href="/contact" class="btn btn-primary">Book a call →</a>
    <a href="https://wa.me/919100933191" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp</a>
  </div>
</div>

<style>
.pricing-row { display: flex; gap: 40px; align-items: center; margin-top: 16px; flex-wrap: wrap; }
.pricing-divider { font-family: 'Syne', sans-serif; font-size: 24px; color: var(--text-muted); }
</style>
