---
export interface Props {
  name: string;
  description: string;
  setupINR: string;
  setupUSD: string;
  href: string;
  category?: string;
}
const { name, description, setupINR, setupUSD, href, category } = Astro.props;
---
<a href={href} class="agent-card card" style="text-decoration:none; display:block;">
  {category && <div class="card-label">{category}</div>}
  <h3>{name}</h3>
  <p>{description}</p>
  <div class="agent-card-price" style="margin-top:16px;">
    <span class="price-inr"><span class="price-amount">{setupINR}</span> <span class="price-recur">setup</span></span>
    <span class="price-usd"><span class="price-amount">{setupUSD}</span> <span class="price-recur">setup</span></span>
  </div>
  <div style="margin-top:12px; font-family:'DM Mono',monospace; font-size:12px; color:var(--accent);">View details →</div>
</a>

<style>
.agent-card { cursor: none; }
.agent-card:hover h3 { color: var(--accent); }
</style>
