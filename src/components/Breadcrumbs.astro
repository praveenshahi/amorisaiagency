---
export interface Crumb { label: string; href?: string; }
export interface Props { crumbs: Crumb[]; }
const { crumbs } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": c.label,
    ...(c.href ? { "item": `https://amoris.in${c.href}` } : {})
  }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<nav class="breadcrumbs" aria-label="Breadcrumb">
  {crumbs.map((c, i) => (
    <>
      {i > 0 && <span>/</span>}
      {c.href ? <a href={c.href}>{c.label}</a> : <span style="color:var(--text-dim)">{c.label}</span>}
    </>
  ))}
</nav>
