---
export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  schema?: string;
}
const { title, description = "Amoris — AI agents, automation, and operating systems for businesses that want to move faster.", ogTitle, schema } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en" data-currency="inr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Amoris" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles/tokens.css" />
  {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}
  <!-- Organization schema -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Amoris",
    "url": "https://amoris.in",
    "description": "AI agents, automation, and operating systems for businesses",
    "address": { "@type": "PostalAddress", "addressCountry": "IN" },
    "contactPoint": { "@type": "ContactPoint", "contactType": "sales", "availableLanguage": ["English", "Hindi"] }
  })}</script>
</head>
<body>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- PRODUCTS BAR -->
  <div class="products-bar">
    <span class="products-bar-label">AI Products</span>
    <div class="products-bar-links">
      <a href="/intel-echo/">Intel Echo — Intelligence Layer</a>
      <a href="/intel-echo-gtm/">Intel Echo GTM — Messaging Loop</a>
    </div>
    <span class="products-bar-domain">amoris.in</span>
  </div>

  <!-- MAIN NAV -->
  <nav class="site-nav">
    <a href="/" class="nav-logo">Amor<span>.</span>is</a>
    <ul class="nav-links">
      <li><a href="/agents">Agents</a></li>
      <li><a href="/automation">Automation</a></li>
      <li><a href="/aios">AIOS</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/work">Work</a></li>
      <li><a href="/about">About</a></li>
    </ul>
    <div class="currency-toggle" id="currencyToggle">
      <button id="btnINR" class="active">₹ INR</button>
      <button id="btnUSD">$ USD</button>
    </div>
    <a href="/contact" class="nav-cta">Book a Call →</a>
  </nav>

  <main>
    <slot />
  </main>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/919100933191" class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <footer>
    <div>
      <div class="footer-logo">Amor<span>.</span>is</div>
      <p style="margin-top:8px;">AI agency. India-built, globally deployable.</p>
    </div>
    <nav class="footer-links">
      <a href="/agents">Agents</a>
      <a href="/automation">Automation</a>
      <a href="/aios">AIOS</a>
      <a href="/pricing">Pricing</a>
      <a href="/work">Work</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
    <p style="font-size:12px; color:var(--text-muted);">© 2026 Amoris. All rights reserved.</p>
  </footer>

  <script>
    // Custom cursor
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cursor.style.left = mx + 'px'; cursor.style.top = my + 'px'; });
    function animateRing() { rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(animateRing); }
    animateRing();
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor.classList.add('hover'); ring.classList.add('hover'); });
      el.addEventListener('mouseleave', () => { cursor.classList.remove('hover'); ring.classList.remove('hover'); });
    });

    // Currency toggle
    const html = document.documentElement;
    const btnINR = document.getElementById('btnINR');
    const btnUSD = document.getElementById('btnUSD');
    const saved = localStorage.getItem('currency') || 'inr';
    html.dataset.currency = saved;
    if (saved === 'usd') { btnINR.classList.remove('active'); btnUSD.classList.add('active'); }
    btnINR.addEventListener('click', () => { html.dataset.currency = 'inr'; localStorage.setItem('currency','inr'); btnINR.classList.add('active'); btnUSD.classList.remove('active'); });
    btnUSD.addEventListener('click', () => { html.dataset.currency = 'usd'; localStorage.setItem('currency','usd'); btnUSD.classList.add('active'); btnINR.classList.remove('active'); });

    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }), { threshold: 0.1 });
    reveals.forEach(el => observer.observe(el));

    // FAQ accordion
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => { q.closest('.faq-item').classList.toggle('open'); });
    });

    // Active nav
    const path = window.location.pathname;
    document.querySelectorAll('.nav-links a').forEach(a => {
      if (path.startsWith(a.getAttribute('href')) && a.getAttribute('href') !== '/') a.classList.add('active');
    });
  </script>
</body>
</html>
