  {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Amoris",
    "url": "https://amoris.in",
    "description": "Amoris is an Indian AI agency that builds and deploys named AI employees — voice agents, chat assistants, and knowledge workers — for businesses.",
    "areaServed": ["IN", "SG", "AE"],
    "address": { "@type": "PostalAddress", "addressCountry": "IN" },
    "contactPoint": [
      { "@type": "ContactPoint", "contactType": "sales", "availableLanguage": ["English", "Hindi"], "url": "https://amoris.in/contact" },
      { "@type": "ContactPoint", "contactType": "customer service", "url": "https://wa.me/919100933191" }
    ]
