  <script>
    /* ── 1. Scroll progress bar ── */
    const progressBar = document.getElementById('scroll-progress') as HTMLElement;
    window.addEventListener('scroll', () => {
      const d = document.documentElement;
      const pct = (d.scrollTop / (d.scrollHeight - d.clientHeight)) * 100;
      if (progressBar) progressBar.style.width = pct + '%';
    }, { passive: true });

    /* ── 2. Custom cursor + spotlight ── */
    const cursor = document.getElementById('cursor') as HTMLElement;
    const ring = document.getElementById('cursorRing') as HTMLElement;
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      if (cursor) { cursor.style.left = mx + 'px'; cursor.style.top = my + 'px'; }
      document.body.style.setProperty('--mx', mx + 'px');
      document.body.style.setProperty('--my', my + 'px');
    }, { passive: true });
    function animRing() {
      rx += (mx - rx) * 0.1; ry += (my - ry) * 0.1;
      if (ring) { ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; }
      requestAnimationFrame(animRing);
    }
    animRing();
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor?.classList.add('hover'); ring?.classList.add('hover'); });
      el.addEventListener('mouseleave', () => { cursor?.classList.remove('hover'); ring?.classList.remove('hover'); });
    });

    /* ── 3. Scroll reveal ── */
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -36px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    /* ── 4. 3D Card tilt ── */
    const TILT_SEL = '.emp-feature-card,.cat-card,.stat-card,.pricing-card,.capability-card,.hiw-step,.package-card,.aios-teaser,.pricing-note-item';
    document.querySelectorAll(TILT_SEL).forEach(card => {
      const el = card as HTMLElement;
      el.style.transformStyle = 'preserve-3d';
      el.style.transition = 'transform 0.15s ease, box-shadow 0.15s ease, border-color 0.25s';
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const nx = ((e.clientX - r.left) / r.width - 0.5) * 2;
        const ny = ((e.clientY - r.top) / r.height - 0.5) * 2;
        el.style.transform = `perspective(900px) rotateY(${nx * 10}deg) rotateX(${-ny * 10}deg) scale(1.02)`;
        el.style.boxShadow = `${-nx * 8}px ${ny * 8}px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(240,168,36,0.14)`;
      });
      el.addEventListener('mouseleave', () => { el.style.transform = ''; el.style.boxShadow = ''; });
    });

    /* ── 5. Magnetic CTA buttons ── */
    document.querySelectorAll('.btn-primary').forEach(btn => {
      const el = btn as HTMLElement;
      document.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const dx = e.clientX - (r.left + r.width / 2);
        const dy = e.clientY - (r.top + r.height / 2);
        const dist = Math.sqrt(dx * dx + dy * dy);
        el.style.transform = dist < 80
          ? `translate(${dx * (1 - dist / 80) * 0.38}px, ${dy * (1 - dist / 80) * 0.38}px)`
          : '';
      }, { passive: true });
    });

    /* ── 6. Text scramble ── */
    const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
    document.querySelectorAll('[data-scramble]').forEach(el => {
      const target = (el as HTMLElement).innerText;
      let iter = 0;
      function tick() {
        (el as HTMLElement).innerText = target.split('').map((ch, i) => {
          if (ch === ' ' || ch === '\n') return ch;
          if (i < iter) return ch;
          return CHARS[Math.floor(Math.random() * CHARS.length)];
        }).join('');
        iter += target.length / 18;
        if (iter < target.length) requestAnimationFrame(tick);
        else (el as HTMLElement).innerText = target;
      }
      setTimeout(tick, 180);
    });

    /* ── 7. FAQ accordion ── */
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => q.closest('.faq-item')?.classList.toggle('open'));
    });

    /* ── 8. Active nav link ── */
    const path = window.location.pathname;
    document.querySelectorAll('.nav-links a, .mobile-nav a').forEach(a => {
      const href = a.getAttribute('href') || '';
      if (href !== '/' && path.startsWith(href)) a.classList.add('active');
    });

    /* ── 9. Mobile nav toggle ── */
    const hamburger = document.getElementById('nav-hamburger') as HTMLElement;
    const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
    hamburger?.addEventListener('click', e => {
      e.stopPropagation();
      const open = mobileNav.classList.toggle('open');
      hamburger.classList.toggle('open', open);
      hamburger.setAttribute('aria-expanded', String(open));
      mobileNav.setAttribute('aria-hidden', String(!open));
    });
    document.addEventListener('click', e => {
      if (!mobileNav?.contains(e.target as Node) && !hamburger?.contains(e.target as Node)) {
        mobileNav?.classList.remove('open');
        hamburger?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
      }
    });

    /* ── 10. Stat counter (vanilla, no GSAP) ── */
    const cObs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseFloat(el.dataset.target || '0');
        const suffix = el.dataset.suffix || '';
        const start = performance.now();
        const dur = 1400;
        function step(now: number) {
          const p = Math.min((now - start) / dur, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = (target % 1 !== 0 ? (target * ease).toFixed(1) : Math.round(target * ease)) + suffix;
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        cObs.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.count-up').forEach(el => cObs.observe(el));

    /* ── 11. GSAP (async, stagger-cards + emp-float) ── */
    const gsapScript = document.createElement('script');
    gsapScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js';
    gsapScript.onload = () => {
      const stScript = document.createElement('script');
      stScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js';
      stScript.onload = () => {
        const { gsap, ScrollTrigger } = window as any;
        gsap.registerPlugin(ScrollTrigger);
        document.querySelectorAll('.stagger-cards').forEach(group => {
          gsap.fromTo(group.querySelectorAll(':scope > *'),
            { y: 40, opacity: 0 },
            { y: 0, opacity: 1, stagger: 0.09, duration: 0.65, ease: 'power2.out',
              scrollTrigger: { trigger: group, start: 'top 87%', toggleActions: 'play none none none' } });
        });
        gsap.to('.emp-float', { y: -10, duration: 2.5, ease: 'sine.inOut', yoyo: true, repeat: -1, stagger: 0.4 });
      };
      document.head.appendChild(stScript);
    };
    document.head.appendChild(gsapScript);
  </script>
</body>
</html>
