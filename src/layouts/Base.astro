  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Amoris",
    "url": "https://amoris.in",
    "description": "AI employees for Indian businesses — voice agents, chat assistants, knowledge workers, and operating systems."
  })}</script>

  {parts.length > 0 && (
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": b.name,
        "item": b.item,
