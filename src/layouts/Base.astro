---
export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  schema?: string;
}
const {
  title,
  description = "Amoris — AI employees for your business. Voice agents, chat assistants, knowledge workers and more. Hire your AI team today.",
  ogTitle,
  schema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const parts = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbs = [
  { name: 'Home', item: 'https://amoris.in/' },
  ...parts.map((part: string, i: number) => ({
    name: part.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    item: 'https://amoris.in/' + parts.slice(0, i + 1).join('/') + '/',
  })),
];
---
<!DOCTYPE html>
<html lang="en">
