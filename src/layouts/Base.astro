---
export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  schema?: string;
}
const { title, description = "Amoris — AI employees for your business. Voice agents, chat assistants, knowledge workers and more. Hire your AI team today.", ogTitle, schema } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Amoris" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Caveat:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles/tokens.css" />

  {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Amoris",
    "url": "https://amoris.in",
    "description": "AI employees — voice agents, chat assistants, knowledge workers, and operating systems for businesses.",
    "address": { "@type": "PostalAddress", "addressCountry": "IN" },
    "contactPoint": { "@type": "ContactPoint", "contactType": "sales", "availableLanguage": ["English", "Hindi"] }
  })}</script>
</head>
<body>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- PRODUCTS BAR -->
  <div class="products-bar">
    <span class="products-bar-label">AI Products</span>
    <div class="products-bar-links">
      <a href="/intel-echo/">Intel Echo — Intelligence Layer</a>
      <a href="/intel-echo-gtm/">Intel Echo GTM — Messaging Loop</a>
    </div>
    <span class="products-bar-domain">amoris.in</span>
  </div>

  <!-- MAIN NAV -->
  <nav class="site-nav">
    <a href="/" class="nav-logo">Amor<span>.</span>is</a>
    <ul class="nav-links">
      <li><a href="/ai-employees">AI Employees</a></li>
      <li><a href="/aios">AIOS</a></li>
      <li><a href="/how-it-works">How It Works</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/work">Case Studies</a></li>
      <li><a href="/about">About</a></li>
    </ul>
    <a href="/contact" class="nav-cta">Book a Demo →</a>
  </nav>

  <main>
    <slot />
  </main>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/919100933191" class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- FOOTER -->
  <div class="footer-main">
    <div>
      <div class="footer-logo">Amor<span>.</span>is</div>
      <p style="margin-top:12px; font-size:13px; max-width:26ch;">AI employees that work while you grow. India-built, globally deployable.</p>
    </div>
    <div>
      <div class="footer-col-title">AI Employees</div>
      <nav class="footer-col-links">
        <a href="/ai-employees/voice">Voice Employees</a>
        <a href="/ai-employees/chat">Chat Employees</a>
        <a href="/ai-employees/knowledge">Knowledge Employees</a>
        <a href="/ai-employees/sales">Sales Employees</a>
        <a href="/ai-employees/operations">Operations Employees</a>
      </nav>
    </div>
    <div>
      <div class="footer-col-title">Company</div>
      <nav class="footer-col-links">
        <a href="/aios">AIOS</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/pricing">Pricing</a>
        <a href="/work">Case Studies</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
    <div>
      <div class="footer-col-title">Products</div>
      <nav class="footer-col-links">
        <a href="/intel-echo/">Intel Echo</a>
        <a href="/intel-echo-gtm/">Intel Echo GTM</a>
      </nav>
      <div style="margin-top:24px;">
        <div class="footer-col-title">Contact</div>
        <a href="https://wa.me/919100933191" style="font-size:13px; color:var(--success);">WhatsApp us</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom-bar">
    <span>© 2026 Amoris. All rights reserved.</span>
    <span>India-built · Globally deployable</span>
  </div>

  <script>
    // Custom cursor
    const cursor = document.getElementById('cursor') as HTMLElement;
    const ring = document.getElementById('cursorRing') as HTMLElement;
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
    });
    function animRing() {
      rx += (mx - rx) * 0.1; ry += (my - ry) * 0.1;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animRing);
    }
    animRing();
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor.classList.add('hover'); ring.classList.add('hover'); });
      el.addEventListener('mouseleave', () => { cursor.classList.remove('hover'); ring.classList.remove('hover'); });
    });

    // Scroll reveal (lightweight IntersectionObserver)
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // FAQ accordion
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => q.closest('.faq-item')?.classList.toggle('open'));
    });

    // Active nav link
    const path = window.location.pathname;
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = a.getAttribute('href') || '';
      if (href !== '/' && path.startsWith(href)) a.classList.add('active');
    });

    // GSAP scroll animations (loaded async to not block render)
    const gsapScript = document.createElement('script');
    gsapScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js';
    gsapScript.onload = () => {
      const stScript = document.createElement('script');
      stScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js';
      stScript.onload = () => {
        // @ts-ignore
        const { gsap, ScrollTrigger } = window as any;
        gsap.registerPlugin(ScrollTrigger);

        // Stagger cards on scroll
        document.querySelectorAll('.stagger-cards').forEach(group => {
          const cards = group.querySelectorAll(':scope > *');
          gsap.fromTo(cards,
            { y: 40, opacity: 0 },
            {
              y: 0, opacity: 1,
              stagger: 0.1,
              duration: 0.7,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: group,
                start: 'top 85%',
                toggleActions: 'play none none none'
              }
            }
          );
        });

        // Stats count-up
        document.querySelectorAll('.count-up').forEach(el => {
          const target = parseFloat(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          const isDecimal = target % 1 !== 0;
          ScrollTrigger.create({
            trigger: el,
            start: 'top 80%',
            once: true,
            onEnter: () => {
              gsap.fromTo({ val: 0 }, { val: target }, {
                duration: 1.8,
                ease: 'power2.out',
                onUpdate: function() {
                  // @ts-ignore
                  el.textContent = (isDecimal ? this.targets()[0].val.toFixed(1) : Math.round(this.targets()[0].val)) + suffix;
                }
              });
            }
          });
        });

        // Hero employees float
        gsap.to('.emp-float', {
          y: -10,
          duration: 2.5,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
          stagger: 0.4
        });
      };
      document.head.appendChild(stScript);
    };
    document.head.appendChild(gsapScript);
  </script>
</body>
</html>
