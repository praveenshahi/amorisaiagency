---
export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  schema?: string;
}
const { title, description = "Amoris — AI employees for your business. Voice agents, chat assistants, knowledge workers and more. Hire your AI team today.", ogTitle, schema } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Amoris" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts — non-blocking load, Inter removed -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Caveat:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  <link rel="stylesheet" media="print" onload="this.media='all'" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Caveat:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Caveat:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" /></noscript>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles/tokens.css" />

  {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Amoris",
    "url": "https://amoris.in",
    "description": "AI employees — voice agents, chat assistants, knowledge workers, and operating systems for businesses.",
    "address": { "@type": "PostalAddress", "addressCountry": "IN" },
    "contactPoint": { "@type": "ContactPoint", "contactType": "sales", "availableLanguage": ["English", "Hindi"] }
  })}</script>
</head>
<body>
  <!-- WebGL Aurora background -->
  <canvas id="auroraCanvas" aria-hidden="true"></canvas>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- PRODUCTS BAR -->
  <div class="products-bar">
    <span class="products-bar-label">AI Products</span>
    <div class="products-bar-links">
      <a href="/intel-echo/">Intel Echo — Intelligence Layer</a>
      <a href="/intel-echo-gtm/">Intel Echo GTM — Messaging Loop</a>
    </div>
    <span class="products-bar-domain">amoris.in</span>
  </div>

  <!-- MAIN NAV -->
  <nav class="site-nav">
    <a href="/" class="nav-logo">Amor<span>.</span>is</a>
    <ul class="nav-links">
      <li><a href="/ai-employees">AI Employees</a></li>
      <li><a href="/aios">AIOS</a></li>
      <li><a href="/how-it-works">How It Works</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/work">Case Studies</a></li>
      <li><a href="/about">About</a></li>
    </ul>
    <a href="/contact" class="nav-cta">Book a Free Audit →</a>
  </nav>

  <main>
    <slot />
  </main>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/919100933191" class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- FOOTER -->
  <div class="footer-main">
    <div>
      <div class="footer-logo">Amor<span>.</span>is</div>
      <p style="margin-top:12px; font-size:13px; max-width:26ch;">AI employees that work while you grow. India-built, globally deployable.</p>
    </div>
    <div>
      <div class="footer-col-title">AI Employees</div>
      <nav class="footer-col-links">
        <a href="/ai-employees/voice">Voice Employees</a>
        <a href="/ai-employees/chat">Chat Employees</a>
        <a href="/ai-employees/knowledge">Knowledge Employees</a>
        <a href="/ai-employees/sales">Sales Employees</a>
        <a href="/ai-employees/operations">Operations Employees</a>
      </nav>
    </div>
    <div>
      <div class="footer-col-title">Company</div>
      <nav class="footer-col-links">
        <a href="/aios">AIOS</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/pricing">Pricing</a>
        <a href="/work">Case Studies</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
    <div>
      <div class="footer-col-title">Products</div>
      <nav class="footer-col-links">
        <a href="/intel-echo/">Intel Echo</a>
        <a href="/intel-echo-gtm/">Intel Echo GTM</a>
      </nav>
      <div style="margin-top:24px;">
        <div class="footer-col-title">Contact</div>
        <a href="https://wa.me/919100933191" style="font-size:13px; color:var(--success);">WhatsApp us</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom-bar">
    <span>© 2026 Amoris. All rights reserved.</span>
    <span>India-built · Globally deployable</span>
  </div>

  <script>
    /* ── 1. WebGL Aurora background ── */
    (function() {
      const canvas = document.getElementById('auroraCanvas') as HTMLCanvasElement;
      if (!canvas) return;
      const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl') as WebGLRenderingContext | null;
      if (!gl) { canvas.style.display = 'none'; return; }

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        (gl as WebGLRenderingContext).viewport(0, 0, canvas.width, canvas.height);
      }
      window.addEventListener('resize', resize);
      resize();

      const vert = `attribute vec2 p; void main(){gl_Position=vec4(p,0,1);}`;
      const frag = `
        precision mediump float;
        uniform float t;
        uniform vec2 res;
        uniform vec2 mouse;

        float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
        float noise(vec2 p){
          vec2 i=floor(p),f=fract(p);
          f=f*f*(3.0-2.0*f);
          return mix(mix(hash(i),hash(i+vec2(1,0)),f.x),
                     mix(hash(i+vec2(0,1)),hash(i+vec2(1,1)),f.x),f.y);
        }
        float fbm(vec2 p){
          float v=0.0,a=0.5;
          for(int i=0;i<5;i++){v+=a*noise(p);p*=2.1;a*=0.5;}
          return v;
        }

        void main(){
          vec2 uv=gl_FragCoord.xy/res;
          uv.y=1.0-uv.y;
          vec2 m=mouse/res; m.y=1.0-m.y;

          float slow=t*0.06;
          vec2 q=vec2(fbm(uv+vec2(0.0,slow)),fbm(uv+vec2(5.2,slow+1.3)));
          vec2 r=vec2(fbm(uv+4.0*q+vec2(1.7,9.2)+0.15*slow),
                      fbm(uv+4.0*q+vec2(8.3,2.8)+0.12*slow));

          float mx=length(uv-m);
          float mousePull=0.04*exp(-mx*mx*6.0);
          float f=fbm(uv+4.0*r+mousePull);

          /* brand palette: teal, gold, purple, near-black */
          vec3 teal   =vec3(0.00,0.80,0.60);
          vec3 gold   =vec3(0.94,0.66,0.14);
          vec3 purple =vec3(0.48,0.23,0.93);
          vec3 dark   =vec3(0.04,0.04,0.044);

          vec3 col=mix(dark, teal,  clamp(f*1.4-0.2,0.0,1.0)*0.55);
          col     =mix(col,  gold,  clamp(r.x*1.3-0.5,0.0,1.0)*0.28);
          col     =mix(col,  purple,clamp(q.y*1.2-0.6,0.0,1.0)*0.22);

          /* vignette */
          float vig=1.0-smoothstep(0.3,1.1,length(uv-0.5)*1.6);
          col*=0.55+0.45*vig;

          gl_FragColor=vec4(col,1.0);
        }
      `;

      function makeShader(type: number, src: string) {
        const s = (gl as WebGLRenderingContext).createShader(type)!;
        (gl as WebGLRenderingContext).shaderSource(s, src);
        (gl as WebGLRenderingContext).compileShader(s);
        return s;
      }
      const prog = (gl as WebGLRenderingContext).createProgram()!;
      (gl as WebGLRenderingContext).attachShader(prog, makeShader((gl as WebGLRenderingContext).VERTEX_SHADER, vert));
      (gl as WebGLRenderingContext).attachShader(prog, makeShader((gl as WebGLRenderingContext).FRAGMENT_SHADER, frag));
      (gl as WebGLRenderingContext).linkProgram(prog);
      (gl as WebGLRenderingContext).useProgram(prog);

      const buf = (gl as WebGLRenderingContext).createBuffer();
      (gl as WebGLRenderingContext).bindBuffer((gl as WebGLRenderingContext).ARRAY_BUFFER, buf);
      (gl as WebGLRenderingContext).bufferData((gl as WebGLRenderingContext).ARRAY_BUFFER,
        new Float32Array([-1,-1,3,-1,-1,3]), (gl as WebGLRenderingContext).STATIC_DRAW);
      const loc = (gl as WebGLRenderingContext).getAttribLocation(prog, 'p');
      (gl as WebGLRenderingContext).enableVertexAttribArray(loc);
      (gl as WebGLRenderingContext).vertexAttribPointer(loc, 2, (gl as WebGLRenderingContext).FLOAT, false, 0, 0);

      const uT   = (gl as WebGLRenderingContext).getUniformLocation(prog, 't');
      const uRes = (gl as WebGLRenderingContext).getUniformLocation(prog, 'res');
      const uMouse = (gl as WebGLRenderingContext).getUniformLocation(prog, 'mouse');

      let mx2 = window.innerWidth / 2, my2 = window.innerHeight / 2;
      document.addEventListener('mousemove', e => { mx2 = e.clientX; my2 = e.clientY; }, { passive: true });

      let start = performance.now();
      let active = true;
      document.addEventListener('visibilitychange', () => { active = document.visibilityState === 'visible'; });

      function draw() {
        requestAnimationFrame(draw);
        if (!active) return;
        const t2 = (performance.now() - start) / 1000;
        (gl as WebGLRenderingContext).uniform1f(uT, t2);
        (gl as WebGLRenderingContext).uniform2f(uRes, canvas.width, canvas.height);
        (gl as WebGLRenderingContext).uniform2f(uMouse, mx2, my2);
        (gl as WebGLRenderingContext).drawArrays((gl as WebGLRenderingContext).TRIANGLES, 0, 3);
      }
      draw();
    })();

    /* ── 2. Custom cursor ── */
    const cursor = document.getElementById('cursor') as HTMLElement;
    const ring = document.getElementById('cursorRing') as HTMLElement;
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
      /* spotlight glow via CSS custom props */
      document.body.style.setProperty('--mx', mx + 'px');
      document.body.style.setProperty('--my', my + 'px');
    }, { passive: true });
    function animRing() {
      rx += (mx - rx) * 0.1; ry += (my - ry) * 0.1;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animRing);
    }
    animRing();
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor.classList.add('hover'); ring.classList.add('hover'); });
      el.addEventListener('mouseleave', () => { cursor.classList.remove('hover'); ring.classList.remove('hover'); });
    });

    /* ── 3. Scroll reveal ── */
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -36px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    /* ── 4. 3D Card tilt ── */
    const TILT_SEL = '.emp-feature-card,.cat-card,.stat-card,.pricing-card,.capability-card,.hiw-step,.package-card,.aios-teaser,.pricing-note-item';
    const MAX_TILT = 10;
    document.querySelectorAll(TILT_SEL).forEach(card => {
      const el = card as HTMLElement;
      el.style.transformStyle = 'preserve-3d';
      el.style.transition = 'transform 0.15s ease, box-shadow 0.15s ease, border-color 0.25s';
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const nx = ((e.clientX - r.left) / r.width  - 0.5) * 2;
        const ny = ((e.clientY - r.top)  / r.height - 0.5) * 2;
        el.style.transform = `perspective(900px) rotateY(${nx * MAX_TILT}deg) rotateX(${-ny * MAX_TILT}deg) scale(1.02)`;
        el.style.boxShadow = `${-nx*8}px ${ny*8}px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(240,168,36,0.14)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'perspective(900px) rotateY(0deg) rotateX(0deg) scale(1)';
        el.style.boxShadow = '';
      });
    });

    /* ── 5. Magnetic CTA buttons ── */
    document.querySelectorAll('.btn-primary').forEach(btn => {
      const el = btn as HTMLElement;
      const RANGE = 80, PULL = 0.38;
      document.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
        const dx = e.clientX - cx, dy = e.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < RANGE) {
          const pull = (1 - dist / RANGE) * PULL;
          el.style.transform = `translate(${dx * pull}px, ${dy * pull}px)`;
        } else {
          el.style.transform = '';
        }
      }, { passive: true });
      el.addEventListener('mouseleave', () => { el.style.transform = ''; });
    });

    /* ── 6. Text scramble on [data-scramble] ── */
    const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
    document.querySelectorAll('[data-scramble]').forEach(el => {
      const target = (el as HTMLElement).innerText;
      let frame = 0, iter = 0;
      const total = 18;
      function tick() {
        (el as HTMLElement).innerText = target.split('').map((ch, i) => {
          if (ch === ' ' || ch === '\n') return ch;
          if (i < iter) return ch;
          return CHARS[Math.floor(Math.random() * CHARS.length)];
        }).join('');
        iter += target.length / total;
        frame++;
        if (iter < target.length) requestAnimationFrame(tick);
        else (el as HTMLElement).innerText = target;
      }
      setTimeout(tick, 180);
    });

    /* ── 7. FAQ accordion ── */
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => q.closest('.faq-item')?.classList.toggle('open'));
    });

    /* ── 8. Active nav link ── */
    const path = window.location.pathname;
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = a.getAttribute('href') || '';
      if (href !== '/' && path.startsWith(href)) a.classList.add('active');
    });

    /* ── 9. GSAP (async, non-blocking) ── */
    const gsapScript = document.createElement('script');
    gsapScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js';
    gsapScript.onload = () => {
      const stScript = document.createElement('script');
      stScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js';
      stScript.onload = () => {
        const { gsap, ScrollTrigger } = window as any;
        gsap.registerPlugin(ScrollTrigger);
        document.querySelectorAll('.stagger-cards').forEach(group => {
          const cards = group.querySelectorAll(':scope > *');
          gsap.fromTo(cards, { y: 40, opacity: 0 }, {
            y: 0, opacity: 1, stagger: 0.09, duration: 0.65, ease: 'power2.out',
            scrollTrigger: { trigger: group, start: 'top 87%', toggleActions: 'play none none none' }
          });
        });
        document.querySelectorAll('.count-up').forEach(el => {
          const target = parseFloat(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          const isDecimal = target % 1 !== 0;
          ScrollTrigger.create({ trigger: el, start: 'top 80%', once: true, onEnter: () => {
            gsap.fromTo({ val: 0 }, { val: target }, { duration: 1.8, ease: 'power2.out',
              onUpdate: function() { el.textContent = (isDecimal ? this.targets()[0].val.toFixed(1) : Math.round(this.targets()[0].val)) + suffix; }
            });
          }});
        });
        gsap.to('.emp-float', { y: -10, duration: 2.5, ease: 'sine.inOut', yoyo: true, repeat: -1, stagger: 0.4 });
      };
      document.head.appendChild(stScript);
    };
    document.head.appendChild(gsapScript);
  </script>
</body>
</html>
