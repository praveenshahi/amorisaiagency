---
import Base from '../../../layouts/Base.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import PricingCard from '../../../components/PricingCard.astro';
import FAQ from '../../../components/FAQ.astro';

export function getStaticPaths() {
  const agents = [
  {
    slug: "lead-research",
    title: "AI Lead Research Agent — Build Enriched Prospect Lists Daily | Amoris",
    description: "An AI agent that builds enriched B2B prospect lists matching your ICP every day and pushes them directly to your CRM.",
    name: "Lead Research Agent",
    answer: "A Lead Research Agent builds a fresh list of enriched prospects matching your ICP every day — company data, decision-maker contacts, recent news signals — and pushes them directly into your CRM. Your team starts each day with warm, researched leads instead of spending hours on manual research.",
    setupINR: "₹1.5L–2.5L", retainerINR: "₹20k/mo", setupUSD: "$3k–5k", retainerUSD: "$400/mo",
    builtFor: ["B2B SaaS", "Consulting & agencies", "IT services", "Staffing", "Financial services"],
    languages: ["English"],
    integrations: ["LinkedIn Sales Navigator", "Apollo.io", "HubSpot", "Zoho CRM", "Salesforce", "Slack"],
    faqs: [
      { q: "Where does the lead data come from?", a: "LinkedIn (via your Sales Navigator account), Apollo.io, Crunchbase, company websites, and public databases. All data aggregated and deduplicated." },
      { q: "How many leads does it produce per day?", a: "Configurable. Typical: 20–50 net-new enriched leads/day matching your ICP. You define the criteria: industry, company size, geography, tech stack, signals like recent funding." },
      { q: "What does 'enriched' mean?", a: "Beyond name and email: company size, funding status, recent news, tech stack, decision-maker contact details, LinkedIn links, and intent signals." },
      { q: "Can it monitor existing prospects for trigger events?", a: "Yes. Set triggers: alert when any of your target accounts raises funding, posts a hiring surge, or mentions a keyword in news." },
      { q: "Does it integrate with my existing CRM?", a: "Yes. Leads pushed directly to HubSpot, Zoho CRM, or Salesforce with all enrichment fields mapped. Deduplication against existing contacts runs before every push." }
    ]
  },
  {
    slug: "outreach-agent",
    title: "AI Outreach Agent — Personalised Email & LinkedIn Sequences at Scale | Amoris",
    description: "An AI agent that writes and sends personalised outreach sequences on email and LinkedIn — tailored to each prospect's context — and triages replies for your sales team.",
    name: "Outreach Agent",
    answer: "An Outreach Agent writes a personalised first-line for every prospect based on their company context, sends sequenced emails and LinkedIn messages at the right intervals, and triages replies — so your sales team spends time on conversations, not sending.",
    setupINR: "₹2L–3.5L", retainerINR: "₹25k/mo", setupUSD: "$4k–7k", retainerUSD: "$500/mo",
    builtFor: ["B2B SaaS", "IT services & consulting", "Staffing", "Agencies", "Financial services"],
    languages: ["English"],
    integrations: ["Gmail", "Outlook", "LinkedIn", "HubSpot", "Zoho CRM", "Salesforce"],
    faqs: [
      { q: "How personalised is the outreach?", a: "Each message is personalised using the prospect's company context: recent news, funding, job postings, LinkedIn activity. The first line is different for every prospect." },
      { q: "How many touchpoints does a sequence have?", a: "Configurable. Default: 5 touchpoints over 14 days. Email 1 (day 1), follow-up (day 4), LinkedIn connection (day 6), LinkedIn message (day 9), final email (day 14)." },
      { q: "What's a realistic reply rate?", a: "For well-targeted B2B with genuinely personalised messages: 8–15% reply rate. Industry average for template blasts: 2–3%." },
      { q: "Does it send on my behalf?", a: "Yes. Connected to your Gmail or Outlook. Messages come from your email address." },
      { q: "How does it triage replies?", a: "Interested → CRM task + Slack alert. Not now → schedule follow-up in 60 days. Not interested → remove from sequence. Unsubscribe → immediately removed." }
    ]
  },
  {
    slug: "crm-copilot",
    title: "AI CRM Copilot — Auto-Update CRM & Draft Follow-Ups After Every Call | Amoris",
    description: "An AI agent that listens to your sales calls, auto-updates your CRM with notes and next steps, drafts follow-up emails, and flags stalling deals.",
    name: "CRM Copilot",
    answer: "A CRM Copilot joins your sales calls, auto-updates deal records with notes and next steps, drafts your follow-up email while you're still on the call, and alerts you to deals that are going silent. Starting at ₹1.75L setup + ₹20k/month.",
    setupINR: "₹1.75L–3L", retainerINR: "₹20k/mo", setupUSD: "$3.5k–6k", retainerUSD: "$400/mo",
    builtFor: ["Sales teams of 3+", "B2B consulting", "Agencies", "Financial services", "Real estate"],
    languages: ["Hindi", "English"],
    integrations: ["Zoom", "Google Meet", "HubSpot", "Zoho CRM", "Salesforce", "Gmail", "Outlook"],
    faqs: [
      { q: "Does it record my calls?", a: "It joins as a participant ('Amoris Notes') and records for transcription. Recording is disclosed to all participants before the call starts. You own all recordings and transcripts." },
      { q: "What CRM fields does it update automatically?", a: "Deal stage, next steps, decision timeline, budget discussed, key concerns raised, follow-up date. You define which fields matter during setup." },
      { q: "Can it draft the follow-up email?", a: "Yes. Within 5 minutes of the call ending, it generates a draft summarising what was discussed, confirming next steps. You review and send — the agent doesn't send without your approval." },
      { q: "How does it flag stalling deals?", a: "Monitors your CRM for deals with no activity in a configurable window (default: 7 days). Sends a daily digest of stalling deals with the last touchpoint and suggested next action." },
      { q: "Does it work with my existing CRM?", a: "Built for HubSpot, Zoho CRM, and Salesforce with custom field mapping done during setup." }
    ]
  }
];
  return agents.map(a => ({ params: { slug: a.slug }, props: { agent: a } }));
}

const { agent } = Astro.props;
---
<Base title={agent.title} description={agent.description}>
<article>
<section style="padding-bottom:40px;">
  <Breadcrumbs crumbs={[{label:"Home",href:"/"},{label:"Agents",href:"/agents"},{label:"Sales & Growth",href:"/agents/sales"},{label:agent.name}]} />
  <div class="section-label reveal">Sales Agent</div>
  <h1 class="reveal" style="margin-bottom:20px;">{agent.name}</h1>
  <div class="card reveal" style="background:var(--surface2); border-color:rgba(200,240,58,0.15); margin-bottom:32px;">
    <p style="font-size:1.05rem; color:var(--text); margin-bottom:16px;">{agent.answer}</p>
    <div style="display:flex; gap:32px; flex-wrap:wrap;">
      <div>
        <div style="font-family:'DM Mono',monospace; font-size:10px; color:var(--text-muted); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:4px;">Starting at</div>
        <span class="price-inr"><span class="price-amount">{agent.setupINR}</span> <span class="price-recur">setup + {agent.retainerINR}</span></span>
        <span class="price-usd"><span class="price-amount">{agent.setupUSD}</span> <span class="price-recur">setup + {agent.retainerUSD}</span></span>
      </div>
    </div>
  </div>
  <div class="reveal" style="margin-bottom:48px;">
    <div class="section-label">Built For</div>
    <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:12px;">
      {agent.builtFor.map((ind: string) => <span style="font-family:'DM Mono',monospace; font-size:12px; color:var(--text-dim); background:var(--surface); border:1px solid var(--border2); padding:4px 14px; border-radius:4px;">{ind}</span>)}
    </div>
  </div>
</section>
<section style="padding-top:0; padding-bottom:48px;">
  <div class="section-label reveal">Integrations</div>
  <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:12px;">
    {agent.integrations.map((int: string) => <span style="font-family:'DM Mono',monospace; font-size:12px; color:var(--text-dim); background:var(--surface); border:1px solid var(--border); padding:4px 14px; border-radius:4px;">{int}</span>)}
  </div>
</section>
<section style="padding-top:0;">
  <PricingCard setupINR={agent.setupINR} retainerINR={agent.retainerINR} setupUSD={agent.setupUSD} retainerUSD={agent.retainerUSD} />
</section>
<section>
  <div class="section-label reveal">FAQ</div>
  <h2 class="reveal" style="margin-bottom:32px;">Common questions about {agent.name}.</h2>
  <FAQ items={agent.faqs} />
</section>
<section style="text-align:center; border-top:1px solid var(--border); background: radial-gradient(ellipse at 50% 100%, var(--accent-dim) 0%, transparent 70%);">
  <h2 style="margin-bottom:16px;">Deploy {agent.name} for your team.</h2>
  <p style="margin:0 auto 32px; max-width:44ch;">Book a 30-minute discovery call.</p>
  <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
    <a href="/contact" class="btn btn-primary">Book a Call →</a>
    <a href="https://wa.me/919100933191" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp us</a>
  </div>
</section>
</article>
</Base>
