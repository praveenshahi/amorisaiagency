---
import Base from '../layouts/Base.astro';
---
<Base title="Contact Amoris — Book a Discovery Call | Amoris" description="Book a 30-minute discovery call with Amoris. We'll map your use case to the right agent, scope the work, and give you a ballpark cost on the call.">
<section>
  <div class="section-label reveal">Contact</div>
  <h1 class="reveal" style="margin-bottom:20px;">Book a Discovery Call.</h1>
  <p class="reveal" style="font-size:1.1rem; max-width:52ch; margin-bottom:48px;">
    30 minutes. No deck. We ask about your operations, you tell us what's eating time or costing money, we tell you what we'd build and roughly what it costs.
  </p>

  <div class="grid-2" style="gap:40px; align-items:start;">
    <div>
      <div class="card reveal" style="padding:40px;">
        <div class="section-label">Via WhatsApp</div>
        <h3 style="margin-bottom:12px;">Fastest way to reach us.</h3>
        <p style="margin-bottom:24px; font-size:14px;">Send a message describing what you're trying to automate. We respond within a few hours (during IST business hours).</p>
        <a href="https://wa.me/919100933191?text=Hi%20Praveen%2C%20I%27d%20like%20to%20discuss%20an%20AI%20agent%20for%20my%20business." class="btn btn-primary" target="_blank" rel="noopener" style="background:#25d366;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp +91 91009 33191
        </a>
      </div>

      <div class="card reveal" style="padding:40px; margin-top:20px;">
        <div class="section-label">Via Email</div>
        <h3 style="margin-bottom:12px;">For detailed enquiries.</h3>
        <p style="margin-bottom:24px; font-size:14px;">If you prefer email — especially for international clients who want to share more context upfront.</p>
        <a href="mailto:amorisprana@gmail.com" class="btn btn-outline">amorisprana@gmail.com</a>
      </div>
    </div>

    <div>
      <div class="card reveal" style="padding:40px;">
        <div class="section-label">What to expect on the call</div>
        <div style="display:flex; flex-direction:column; gap:0; margin-top:8px;">
          {[
            { n: "01", t: "You describe the problem", d: "What's taking the most time, where leads are getting lost, what's being done manually that shouldn't be." },
            { n: "02", t: "We identify the fit", d: "We name the agent type, scope the integration, and tell you what would and wouldn't work." },
            { n: "03", t: "Ballpark cost on the call", d: "Not a 'we'll send you a proposal in 5 days'. You get a range on the call based on what we've heard." },
            { n: "04", t: "Next step if it makes sense", d: "Either a deeper scoping session or a proposal. Nothing is pushed." },
          ].map(step => (
            <div style="padding:16px 0; border-bottom:1px solid var(--border); display:flex; gap:16px;">
              <div style="font-family:'DM Mono',monospace; font-size:12px; color:var(--accent); min-width:24px; flex-shrink:0;">{step.n}</div>
              <div>
                <h3 style="font-size:14px; margin-bottom:4px;">{step.t}</h3>
                <p style="font-size:13px; margin:0;">{step.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="card reveal" style="padding:32px; margin-top:20px; background:var(--surface2);">
        <div class="section-label">Good fit for a call if you are:</div>
        <ul style="list-style:none; margin-top:12px;">
          {[
            "A business with 5–500 employees looking to automate specific operations",
            "Spending ₹15k+/month on a function that could be automated",
            "Already using CRM, WhatsApp Business, or email marketing tools",
            "Interested in deploying within 60 days, not 'exploring for next year'",
          ].map(pt => (
            <li style="font-family:'DM Mono',monospace; font-size:12px; color:var(--text-dim); padding:6px 0; border-bottom:1px solid var(--border); display:flex; gap:10px;">
              <span style="color:var(--accent);">→</span> {pt}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
</Base>
