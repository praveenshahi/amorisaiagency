---
import Base from '../layouts/Base.astro';
---
<Base title="Amoris — AI Agents, Automation & Operating Systems for Business" description="Amoris builds AI agents that handle your inbound calls, WhatsApp, documents, lead research, and reporting. Named systems. Public pricing. India-built.">

<!-- HERO -->
<section style="padding-top:80px; padding-bottom:80px; max-width:var(--max-w); margin:0 auto; padding-left:48px; padding-right:48px;">
  <div class="section-label reveal">AI Agency</div>
  <h1 class="reveal" style="margin-bottom:24px; max-width:18ch;">
    Your business runs on <em>agents</em> now.
  </h1>
  <p class="reveal" style="font-size:1.15rem; max-width:52ch; margin-bottom:40px; color:var(--text-dim);">
    Named AI systems that answer your calls, handle your WhatsApp, research your leads, process your documents, and generate your reports. Not custom software. Deployable in weeks.
  </p>
  <div class="reveal" style="display:flex; gap:16px; flex-wrap:wrap;">
    <a href="/agents" class="btn btn-primary">Explore Agents →</a>
    <a href="/contact" class="btn btn-outline">Book a Discovery Call</a>
  </div>

  <!-- HERO DIAGRAM -->
  <div class="hero-diagram reveal" style="margin-top:72px;">
    <svg viewBox="0 0 900 280" xmlns="http://www.w3.org/2000/svg" style="width:100%; max-width:900px;">
      <defs>
        <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="rgba(200,240,58,0.5)" />
        </marker>
      </defs>
      <!-- Nodes -->
      <g>
        <!-- Voice -->
        <rect x="20" y="100" width="160" height="80" rx="6" fill="#17160f" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
        <text x="100" y="132" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778" letter-spacing="0.08em">VOICE AI</text>
        <text x="100" y="155" text-anchor="middle" font-family="Syne, sans-serif" font-size="14" font-weight="700" fill="#f0ede4">AI Receptionist</text>
        <text x="100" y="172" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#c8f03a">24/7 · 6 languages</text>
        <!-- Chat -->
        <rect x="240" y="20" width="160" height="80" rx="6" fill="#17160f" stroke="rgba(200,240,58,0.15)" stroke-width="1"/>
        <text x="320" y="52" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778" letter-spacing="0.08em">CHAT</text>
        <text x="320" y="75" text-anchor="middle" font-family="Syne, sans-serif" font-size="14" font-weight="700" fill="#f0ede4">WhatsApp Agent</text>
        <text x="320" y="92" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#c8f03a">Orders · Support · Commerce</text>
        <!-- Knowledge -->
        <rect x="500" y="100" width="160" height="80" rx="6" fill="#17160f" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
        <text x="580" y="132" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778" letter-spacing="0.08em">KNOWLEDGE</text>
        <text x="580" y="155" text-anchor="middle" font-family="Syne, sans-serif" font-size="14" font-weight="700" fill="#f0ede4">Document Intelligence</text>
        <text x="580" y="172" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#c8f03a">Contracts · Invoices · Reports</text>
        <!-- Ops -->
        <rect x="240" y="180" width="160" height="80" rx="6" fill="#17160f" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
        <text x="320" y="212" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778" letter-spacing="0.08em">OPERATIONS</text>
        <text x="320" y="235" text-anchor="middle" font-family="Syne, sans-serif" font-size="14" font-weight="700" fill="#f0ede4">Reporting Agent</text>
        <text x="320" y="252" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#c8f03a">Daily · Weekly · Client</text>
        <!-- AIOS centre -->
        <rect x="700" y="90" width="175" height="100" rx="6" fill="#1e1d14" stroke="rgba(200,240,58,0.3)" stroke-width="1.5"/>
        <text x="787" y="122" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#c8f03a" letter-spacing="0.1em">FLAGSHIP</text>
        <text x="787" y="145" text-anchor="middle" font-family="Syne, sans-serif" font-size="16" font-weight="800" fill="#f0ede4">Amoris AIOS</text>
        <text x="787" y="165" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778">All agents. Shared memory.</text>
        <text x="787" y="181" text-anchor="middle" font-family="DM Mono, monospace" font-size="10" fill="#8a8778">One command centre.</text>
      </g>
      <!-- Arrows -->
      <line x1="180" y1="140" x2="240" y2="80" stroke="rgba(200,240,58,0.25)" stroke-width="1" marker-end="url(#arrowhead)" stroke-dasharray="4,3">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2s" repeatCount="indefinite"/>
      </line>
      <line x1="400" y1="60" x2="500" y2="120" stroke="rgba(200,240,58,0.25)" stroke-width="1" marker-end="url(#arrowhead)" stroke-dasharray="4,3">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.4s" repeatCount="indefinite"/>
      </line>
      <line x1="500" y1="160" x2="400" y2="200" stroke="rgba(200,240,58,0.25)" stroke-width="1" marker-end="url(#arrowhead)" stroke-dasharray="4,3">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="1.8s" repeatCount="indefinite"/>
      </line>
      <line x1="240" y1="220" x2="180" y2="160" stroke="rgba(200,240,58,0.25)" stroke-width="1" marker-end="url(#arrowhead)" stroke-dasharray="4,3">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.2s" repeatCount="indefinite"/>
      </line>
      <line x1="660" y1="140" x2="700" y2="140" stroke="rgba(200,240,58,0.4)" stroke-width="1.5" marker-end="url(#arrowhead)"/>
    </svg>
  </div>
</section>

<!-- TICKER -->
<div class="ticker-wrap" style="border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:12px 0; overflow:hidden; background:var(--surface);">
  <div class="ticker" style="display:flex; gap:48px; white-space:nowrap; animation:ticker 40s linear infinite;">
    {['AI Receptionist', 'WhatsApp Agent', 'Lead Research', 'Document Intelligence', 'Outbound Follow-Up', 'Internal Knowledge', 'CRM Copilot', 'Reporting Agent', 'Appointment Booking', 'Lead Qualification', 'Instagram DM Agent', 'Compliance Agent', 'Outreach Agent', 'Recruiting Agent', 'Invoice Processing', 'Customer Docs Agent', 'Payment Reminders', 'Website Support'].map(name => (
      <span style="font-family:'DM Mono',monospace; font-size:12px; color:var(--text-dim); letter-spacing:0.06em;">{name} <span style="color:var(--accent); margin-left:24px;">·</span></span>
    ))}
  </div>
</div>

<!-- 4 DIVISIONS -->
<section class="reveal">
  <div class="section-label">What We Build</div>
  <h2 style="margin-bottom:12px;">Four ways to deploy AI in your business.</h2>
  <p style="margin-bottom:48px;">Start with one agent. Grow into an operating system.</p>
  <div class="grid-2">
    <a href="/agents" class="card division-card" style="text-decoration:none; display:block;">
      <div class="card-label">Division 01</div>
      <h3 style="font-size:1.4rem; margin-bottom:12px;">AI Agents</h3>
      <p>18 named agent types across voice, chat, knowledge, sales, and operations. Each one does a specific job, deployed in 3–4 weeks.</p>
      <div style="margin-top:20px; font-family:'DM Mono',monospace; font-size:12px; color:var(--accent);">18 agent types →</div>
    </a>
    <a href="/automation" class="card division-card" style="text-decoration:none; display:block;">
      <div class="card-label">Division 02</div>
      <h3 style="font-size:1.4rem; margin-bottom:12px;">AI Automation</h3>
      <p>Connect your tools so work flows without humans pushing it. CRM ↔ email ↔ Sheets ↔ WhatsApp pipelines built and maintained.</p>
      <div style="margin-top:20px; font-family:'DM Mono',monospace; font-size:12px; color:var(--accent);">Automation services →</div>
    </a>
    <a href="/aios" class="card division-card" style="text-decoration:none; display:block; border-color:var(--accent-dim);">
      <div class="card-label" style="color:var(--accent);">Division 03 — Flagship</div>
      <h3 style="font-size:1.4rem; margin-bottom:12px;">Amoris AIOS</h3>
      <p>Not one agent — an operating system. Multiple agents, shared memory, one command centre. This is where clients graduate to.</p>
      <div style="margin-top:20px; font-family:'DM Mono',monospace; font-size:12px; color:var(--accent);">See AIOS →</div>
    </a>
    <a href="/pricing" class="card division-card" style="text-decoration:none; display:block;">
      <div class="card-label">Division 04</div>
      <h3 style="font-size:1.4rem; margin-bottom:12px;">Strategy & Enablement</h3>
      <p>Not ready to build yet? Start with an AI Opportunity Audit — 2 weeks, full roadmap with ROI projections. Fee credited to any build.</p>
      <div style="margin-top:20px; font-family:'DM Mono',monospace; font-size:12px; color:var(--accent);">See services →</div>
    </a>
  </div>
</section>

<!-- FEATURED AGENTS -->
<section style="border-top:1px solid var(--border);">
  <div class="section-label reveal">Most Deployed</div>
  <h2 class="reveal" style="margin-bottom:40px;">The agents clients start with.</h2>
  <div class="grid-3">
    <a href="/agents/voice/ai-receptionist" class="card" style="text-decoration:none; display:block;" >
      <div class="card-label">Voice</div>
      <h3>AI Receptionist</h3>
      <p>Answers every call 24/7 in 6 languages. Books appointments. Never misses.</p>
      <div style="margin-top:16px;">
        <span class="price-inr"><span class="price-amount">₹1.5L</span> <span class="price-recur">setup</span></span>
        <span class="price-usd"><span class="price-amount">$3k</span> <span class="price-recur">setup</span></span>
      </div>
    </a>
    <a href="/agents/chat/whatsapp-agent" class="card" style="text-decoration:none; display:block;">
      <div class="card-label">Chat</div>
      <h3>WhatsApp Business Agent</h3>
      <p>Full commerce on WhatsApp. Orders, payments, support — without a human agent for 80% of queries.</p>
      <div style="margin-top:16px;">
        <span class="price-inr"><span class="price-amount">₹1.25L</span> <span class="price-recur">setup</span></span>
        <span class="price-usd"><span class="price-amount">$2.5k</span> <span class="price-recur">setup</span></span>
      </div>
    </a>
    <a href="/agents/knowledge/internal-knowledge" class="card" style="text-decoration:none; display:block;">
      <div class="card-label">Knowledge</div>
      <h3>Internal Knowledge Agent</h3>
      <p>Staff ask questions. Agent answers from your SOPs and policies. With sources.</p>
      <div style="margin-top:16px;">
        <span class="price-inr"><span class="price-amount">₹2L</span> <span class="price-recur">setup</span></span>
        <span class="price-usd"><span class="price-amount">$4k</span> <span class="price-recur">setup</span></span>
      </div>
    </a>
  </div>
</section>

<!-- TRUST SIGNALS -->
<section style="border-top:1px solid var(--border);">
  <div class="grid-3">
    <div class="reveal">
      <div style="font-family:'DM Mono',monospace; font-size:32px; font-weight:400; color:var(--accent);">3–4 wks</div>
      <h3 style="margin:8px 0 4px;">Time to go live</h3>
      <p style="font-size:14px;">From signed agreement to live agent handling real calls or messages.</p>
    </div>
    <div class="reveal">
      <div style="font-family:'DM Mono',monospace; font-size:32px; font-weight:400; color:var(--accent);">6 langs</div>
      <h3 style="margin:8px 0 4px;">Voice agent languages</h3>
      <p style="font-size:14px;">Hindi, English, Tamil, Telugu, Kannada, Marathi. Auto-detected per caller.</p>
    </div>
    <div class="reveal">
      <div style="font-family:'DM Mono',monospace; font-size:32px; font-weight:400; color:var(--accent);">18 types</div>
      <h3 style="margin:8px 0 4px;">Named agent systems</h3>
      <p style="font-size:14px;">Not "AI solutions" — specific systems with specific names, scopes, and prices.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="text-align:center; border-top:1px solid var(--border); background: radial-gradient(ellipse at 50% 100%, var(--accent-dim) 0%, transparent 70%);">
  <div class="section-label reveal">Start Here</div>
  <h2 class="reveal" style="margin-bottom:16px;">Not sure where to start?</h2>
  <p class="reveal" style="margin:0 auto 36px; max-width:44ch; font-size:1.05rem;">Book a 30-minute discovery call. We'll map one specific problem to one specific agent — and give you a ballpark scope and cost on the call.</p>
  <div class="reveal" style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
    <a href="/contact" class="btn btn-primary">Book a Discovery Call →</a>
    <a href="/pricing" class="btn btn-outline">See Pricing</a>
  </div>
</section>

<style>
.division-card:hover h3 { color: var(--accent); }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
</style>
</Base>
