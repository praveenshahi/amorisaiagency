---
import Base from '../layouts/Base.astro';
import BookAuditCTA from '../components/BookAuditCTA.astro';

const featured = [
  {
    slug: '/ai-employees/voice/ai-receptionist',
    name: 'AI Receptionist',
    category: 'Voice',
    icon: '📞',
    color: '#7C3AED',
    bg: 'rgba(124,58,237,0.12)',
    job: 'Answers every call 24/7 in 6 languages. Books appointments. Never goes on leave.',
  },
  {
    slug: '/ai-employees/chat/ai-whatsapp-assistant',
    name: 'AI WhatsApp Assistant',
    category: 'Chat',
    icon: '💬',
    color: '#22C55E',
    bg: 'rgba(34,197,94,0.12)',
    job: 'Handles orders, support and payments on WhatsApp. 80% of queries resolved without a human.',
  },
  {
    slug: '/ai-employees/voice/ai-voice-sales-agent',
    name: 'AI Voice Sales Agent',
    category: 'Voice',
    icon: '🎯',
    color: '#F0A824',
    bg: 'rgba(240,168,36,0.12)',
    job: 'Calls your leads, qualifies them, and books meetings — while your team focuses on closing.',
  },
  {
    slug: '/ai-employees/chat/ai-lead-qualifier',
    name: 'AI Lead Qualifier',
    category: 'Chat',
    icon: '⚡',
    color: '#3B82F6',
    bg: 'rgba(59,130,246,0.12)',
    job: 'Qualifies every inbound lead instantly. No more unqualified calls on your calendar.',
  },
  {
    slug: '/ai-employees/knowledge/ai-company-brain',
    name: 'AI Company Brain',
    category: 'Knowledge',
    icon: '🧠',
    color: '#06B6D4',
    bg: 'rgba(6,182,212,0.12)',
    job: 'Your entire company knowledge — SOPs, policies, docs — searchable by any employee, instantly.',
  },
];

const categories = [
  { name: 'Voice', count: 4, href: '/ai-employees/voice', icon: '🎙️', desc: 'Calls, appointments, reminders' },
  { name: 'Chat', count: 4, href: '/ai-employees/chat', icon: '💬', desc: 'WhatsApp, website, Instagram' },
  { name: 'Knowledge', count: 4, href: '/ai-employees/knowledge', icon: '🧠', desc: 'Docs, compliance, help desk' },
  { name: 'Sales', count: 3, href: '/ai-employees/sales', icon: '🎯', desc: 'Leads, outreach, CRM' },
  { name: 'Operations', count: 3, href: '/ai-employees/operations', icon: '⚙️', desc: 'Reports, invoices, recruiting' },
];

const howItWorks = [
  { n: '01', title: 'Book a Demo', body: 'Tell us your biggest time-drain or missed-revenue problem. 30 minutes. We map it to a specific AI employee.' },
  { n: '02', title: 'We Build & Deploy', body: 'Our team builds, tests, and deploys your AI employee in 3–4 weeks. Integrated into your existing tools.' },
  { n: '03', title: 'It Works. You Grow.', body: 'Your AI employee handles the repetitive work 24/7. You focus on strategy, clients, and growth.' },
];

const stats = [
  { value: '3', suffix: '–4 wks', label: 'Average time to go live', sub: 'From signed agreement to live deployment' },
  { value: '6', suffix: ' langs', label: 'Voice agent languages', sub: 'Hindi, English, Tamil, Telugu, Kannada, Marathi' },
  { value: '18', suffix: ' types', label: 'Named AI employee types', sub: 'Each with a defined scope, not "AI solutions"' },
  { value: '24', suffix: '/7', label: 'Always on', sub: 'No sick days. No leaves. No missed calls.' },
];
---
<Base
  title="Amoris — Hire AI Employees. They Work While You Grow."
  description="Hire AI receptionists, voice agents, WhatsApp assistants, and knowledge workers for your business. Named AI employees with clear pricing. Deployed in 3–4 weeks."
>

<!-- ── HERO ─────────────────────────────────────────────────────── -->
<section class="hero-section">
  <div class="hero-left">
    <span class="section-eyebrow">AI EMPLOYEES THAT WORK 24/7</span>
    <h1 class="hero-h1" data-scramble>
      Hire AI Employees.<br/>
      <span class="gradient-text">They work while</span><br/>
      you grow.
    </h1>
    <p class="hero-sub">
      AI receptionists, voice agents, chat assistants and more.
      Built to save time, win customers and scale your business.
    </p>
    <div class="hero-ctas">
      <a href="/ai-employees" class="btn btn-primary">Hire Your AI Employee →</a>
      <a href="/how-it-works" class="btn btn-outline">See How It Works</a>
    </div>
    <div class="hero-trust">
      <span class="live-dot"></span>
      <span style="font-size:13px; color:var(--text-muted); font-family:var(--font-mono);">
        Deployed across India and beyond
      </span>
    </div>
  </div>

  <div class="hero-right reveal reveal-d2">
    <div class="home-robot-stage" aria-label="Interactive Amoris AI employee robot preview">
      <div class="home-robot-bg-text" aria-hidden="true">AI TEAM</div>
      <div id="amorisHomeRobotCanvas" class="home-robot-canvas" aria-label="Interactive AI robot. Move your pointer to make it look around. Tap to trigger heart eyes."></div>
      <div class="home-robot-orbit" aria-hidden="true"></div>
      <div class="home-robot-chip chip-voice">
        <span class="live-dot"></span>
        <strong>AI Receptionist</strong>
        <small>18 calls handled</small>
      </div>
      <div class="home-robot-chip chip-chat">
        <span class="live-dot"></span>
        <strong>WhatsApp Assistant</strong>
        <small>42 chats resolved</small>
      </div>
      <div class="home-robot-chip chip-brain">
        <span class="live-dot"></span>
        <strong>Company Brain</strong>
        <small>SOPs synced</small>
      </div>
      <div class="home-robot-caption">
        <span class="script-annotation">Your AI Team</span>
        <small>Move pointer. Tap robot.</small>
      </div>
    </div>
  </div>

  <!-- Gold glow blob -->
  <div class="hero-glow" aria-hidden="true"></div>
</section>

<BookAuditCTA heading="Seen enough? Let's find your first AI employee." sub="Book a free 30-minute audit. We'll identify the highest-impact automation in your business and show you exactly what to build first." />

<!-- ── TICKER ────────────────────────────────────────────────────── -->
<div class="ticker-wrap" style="border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:13px 0;">
  <div class="ticker-track">
    {[...['AI Receptionist','AI WhatsApp Assistant','AI Voice Sales Agent','AI Lead Qualifier','AI Company Brain','AI Booking Assistant','AI Collections Caller','AI Support Assistant','AI Social Responder','AI Document Analyst','AI Help Desk','AI Compliance Assistant','AI Prospector','AI Outreach Rep','AI Sales Coordinator','AI Business Analyst','AI Back-Office Clerk','AI Recruiter'], ...['AI Receptionist','AI WhatsApp Assistant','AI Voice Sales Agent','AI Lead Qualifier','AI Company Brain','AI Booking Assistant','AI Collections Caller','AI Support Assistant','AI Social Responder','AI Document Analyst','AI Help Desk','AI Compliance Assistant','AI Prospector','AI Outreach Rep','AI Sales Coordinator','AI Business Analyst','AI Back-Office Clerk','AI Recruiter']].map(name => (
      <span class="ticker-item">{name} <span class="ticker-dot">·</span></span>
    ))}
  </div>
</div>

<!-- ── FEATURED EMPLOYEES ─────────────────────────────────────────── -->
<section>
  <span class="section-eyebrow reveal">Ready to Deploy</span>
  <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:40px; flex-wrap:wrap; gap:16px;">
    <h2 class="reveal" style="max-width:20ch;">Meet your new AI employees.</h2>
    <a href="/ai-employees" class="btn btn-outline reveal">Explore all 18 →</a>
  </div>
  <div class="emp-grid stagger-cards">
    {featured.map(emp => (
      <a href={emp.slug} class="emp-feature-card" style={`--emp-color: ${emp.color}; --emp-bg: ${emp.bg};`}>
        <div class="emp-feature-top">
          <div class="emp-feature-icon">{emp.icon}</div>
          <span class="tag">{emp.category}</span>
        </div>
        <h3 class="emp-feature-name">{emp.name}</h3>
        <p class="emp-feature-job">{emp.job}</p>
        <div class="emp-feature-footer">
          <span class="emp-feature-link">View details →</span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ── CATEGORIES ────────────────────────────────────────────────── -->
<section style="border-top:1px solid var(--border);">
  <span class="section-eyebrow reveal">Browse by Type</span>
  <h2 class="reveal" style="margin-bottom:32px;">18 AI employees across 5 departments.</h2>
  <div class="cat-grid stagger-cards">
    {categories.map(cat => (
      <a href={cat.href} class="cat-card">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:24px;">{cat.icon}</span>
          <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted);">{cat.count} employees</span>
        </div>
        <div style="font-family:var(--font-display); font-weight:700; font-size:1.05rem; margin-bottom:4px; color:var(--text);">{cat.name}</div>
        <div style="font-size:12px; color:var(--text-muted);">{cat.desc}</div>
      </a>
    ))}
  </div>
</section>

<!-- ── HOW IT WORKS ──────────────────────────────────────────────── -->
<section style="border-top:1px solid var(--border);" class="hiw-section">
  <div class="hiw-left">
    <span class="section-eyebrow reveal">Process</span>
    <h2 class="reveal" style="margin-bottom:40px;">Up and running in weeks,<br/>not months.</h2>
    <div class="hiw-steps stagger-cards">
      {howItWorks.map(step => (
        <div class="hiw-step">
          <div class="hiw-step-n">{step.n}</div>
          <div>
            <div style="font-family:var(--font-display); font-weight:700; margin-bottom:6px; color:var(--text);">{step.title}</div>
            <p style="font-size:14px;">{step.body}</p>
          </div>
        </div>
      ))}
    </div>
    <div style="margin-top:40px;">
      <a href="/how-it-works" class="btn btn-outline">Full process →</a>
    </div>
  </div>

  <div class="hiw-right reveal">
    <!-- Network diagram SVG -->
    <svg class="network-svg" viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
      <!-- Center Amoris circle -->
      <circle cx="160" cy="160" r="44" fill="rgba(240,168,36,0.08)" stroke="rgba(240,168,36,0.3)" stroke-width="1.5"/>
      <text x="160" y="155" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700" fill="#F5F3EE">Amoris</text>
      <text x="160" y="172" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#F0A824">AI OS</text>

      <!-- Orbit lines (dashed) -->
      <circle cx="160" cy="160" r="110" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1" stroke-dasharray="4,6"/>

      <!-- Tool nodes & connecting lines -->
      <!-- WhatsApp (top) -->
      <line x1="160" y1="116" x2="160" y2="58" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2s" repeatCount="indefinite"/>
      </line>
      <circle cx="160" cy="46" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="160" y="43" text-anchor="middle" font-size="14">💬</text>
      <text x="160" y="57" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">WhatsApp</text>

      <!-- Gmail (upper right) -->
      <line x1="191" y1="135" x2="238" y2="92" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.4s" repeatCount="indefinite"/>
      </line>
      <circle cx="252" cy="80" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="252" y="77" text-anchor="middle" font-size="14">📧</text>
      <text x="252" y="91" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">Gmail</text>

      <!-- CRM (right) -->
      <line x1="204" y1="160" x2="262" y2="160" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="1.8s" repeatCount="indefinite"/>
      </line>
      <circle cx="276" cy="160" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="276" y="157" text-anchor="middle" font-size="14">🗂️</text>
      <text x="276" y="171" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">CRM</text>

      <!-- Calendar (lower right) -->
      <line x1="191" y1="185" x2="238" y2="228" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.2s" repeatCount="indefinite"/>
      </line>
      <circle cx="252" cy="242" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="252" y="239" text-anchor="middle" font-size="14">📅</text>
      <text x="252" y="253" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">Calendar</text>

      <!-- Sheets (lower left) -->
      <line x1="129" y1="185" x2="82" y2="228" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="2.6s" repeatCount="indefinite"/>
      </line>
      <circle cx="68" cy="242" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="68" y="239" text-anchor="middle" font-size="14">📊</text>
      <text x="68" y="253" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">Sheets</text>

      <!-- Slack (left) -->
      <line x1="116" y1="160" x2="58" y2="160" stroke="rgba(240,168,36,0.2)" stroke-width="1" stroke-dasharray="3,4">
        <animate attributeName="stroke-dashoffset" from="0" to="-14" dur="3s" repeatCount="indefinite"/>
      </line>
      <circle cx="44" cy="160" r="24" fill="#1C1C1F" stroke="#26262A" stroke-width="1"/>
      <text x="44" y="157" text-anchor="middle" font-size="14">💼</text>
      <text x="44" y="171" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#9B9891">Slack</text>
    </svg>
    <p style="text-align:center; font-family:var(--font-mono); font-size:11px; color:var(--text-muted); margin-top:16px;">Connects to your existing tools</p>
  </div>
</section>

<BookAuditCTA heading="Ready to put AI to work in your business?" />

<!-- ── STATS ────────────────────────────────────────────────────── -->
<section style="border-top:1px solid var(--border);" class="stats-section">
  <div class="stats-grid stagger-cards">
    {stats.map(s => (
      <div class="stat-card">
        <div class="stat-value">
          <span style="font-family:var(--font-display); font-size:2.8rem; font-weight:700; color:var(--gold);">{s.value}</span>
          <span style="font-family:var(--font-display); font-size:1.4rem; font-weight:600; color:var(--gold-bright);">{s.suffix}</span>
        </div>
        <div style="font-weight:600; font-family:var(--font-display); margin-bottom:4px;">{s.label}</div>
        <p style="font-size:13px;">{s.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ── AIOS TEASER ───────────────────────────────────────────────── -->
<section style="border-top:1px solid var(--border);">
  <div class="aios-teaser reveal">
    <div class="aios-teaser-inner">
      <span class="tag-gold" style="font-size:10px; letter-spacing:0.1em; text-transform:uppercase; font-family:var(--font-mono);">Flagship</span>
      <h2 style="margin-top:20px; margin-bottom:16px;">Start with one employee.<br/>Graduate to an <em style="font-style:italic; color:var(--gold);">AI operating system.</em></h2>
      <p style="max-width:52ch; margin-bottom:32px;">Amoris AIOS brings all your AI employees together — shared memory, one command centre, cross-agent workflows. Not just tools. A workforce.</p>
      <a href="/aios" class="btn btn-primary">Explore AIOS →</a>
    </div>
    <div class="aios-glow" aria-hidden="true"></div>
  </div>
</section>

<!-- ── CTA BANNER ───────────────────────────────────────────────── -->
<section class="cta-section glow-section">
  <div class="cta-inner reveal">
    <span class="section-eyebrow">Start here</span>
    <h2 style="margin-bottom:12px;">
      Ready to hire your<br/>
      <span class="gradient-text">first AI employee?</span>
    </h2>
    <p style="max-width:44ch; margin: 0 auto 36px;">Book a 30-minute discovery call. We'll map your problem to the right AI employee — and give you a scope and ballpark cost on the call.</p>
    <div class="cta-btns">
      <a href="/contact" class="btn btn-primary" style="font-size:15px; padding:14px 32px;">Book a Free Audit →</a>
      <a href="https://wa.me/919100933191" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp us</a>
    </div>
    <p style="margin-top:20px; font-size:12px; font-family:var(--font-mono);">No commitment. 30 minutes. Get a clear answer.</p>
  </div>
</section>

<style>
/* ── Hero ── */
.hero-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  padding: 90px 48px 80px;
  max-width: var(--max-w);
  margin: 0 auto;
  position: relative;
  overflow: hidden;
}
@media (max-width: 900px) {
  .hero-section { grid-template-columns: 1fr; padding: 60px 24px; }
  .hero-right { order: -1; }
}
.hero-h1 {
  font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  line-height: 1.1;
  margin-bottom: 20px;
  letter-spacing: -0.03em;
}
.hero-sub { font-size: 1.05rem; max-width: 46ch; margin-bottom: 36px; line-height: 1.65; }
.hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }
.hero-trust { display: flex; align-items: center; gap: 10px; }
.hero-right { position: relative; min-height: 520px; }
.home-robot-stage {
  position: relative;
  min-height: 560px;
  border-radius: 22px;
  overflow: hidden;
  isolation: isolate;
  background:
    radial-gradient(ellipse at 48% 30%, rgba(0,255,198,.14), transparent 48%),
    radial-gradient(ellipse at 82% 75%, rgba(240,168,36,.10), transparent 42%),
    radial-gradient(ellipse at 16% 78%, rgba(124,58,237,.08), transparent 38%),
    #0C0C0E;
  border: 1px solid rgba(0,255,198,.16);
  box-shadow: 0 26px 90px rgba(0,0,0,.72), 0 0 0 1px rgba(255,255,255,.03),
    inset 0 1px 0 rgba(255,255,255,.05), 0 0 80px rgba(0,255,198,.04);
}
.home-robot-stage::before { display: none; }
.home-robot-stage::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 88% 82% at 50% 46%, transparent 0%, rgba(12,12,14,.84) 100%);
  pointer-events: none;
  z-index: 2;
}
.home-robot-bg-text {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: rgba(255,255,255,.04);
  font-family: var(--font-display);
  font-size: clamp(4.8rem, 11vw, 8.4rem);
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1;
  z-index: 0;
  transform: translateY(30px);
  user-select: none;
  white-space: nowrap;
}
.home-robot-canvas {
  position: absolute;
  inset: 0;
  z-index: 2;
  cursor: pointer;
  touch-action: manipulation;
}
.home-robot-canvas canvas { display: block; width: 100%; height: 100%; }
.home-robot-orbit {
  position: absolute;
  left: 50%;
  top: 50%;
  width: min(74%, 430px);
  aspect-ratio: 1;
  transform: translate(-50%, -48%);
  border: 1px solid rgba(240,168,36,0.13);
  border-radius: 50%;
  z-index: 1;
}
.home-robot-orbit::before,
.home-robot-orbit::after {
  content: '';
  position: absolute;
  inset: 13%;
  border: 1px dashed rgba(255,255,255,0.07);
  border-radius: 50%;
}
.home-robot-orbit::after {
  inset: 29%;
  border-color: rgba(0,255,198,0.09);
}
.home-robot-chip {
  position: absolute;
  z-index: 3;
  display: grid;
  grid-template-columns: auto 1fr;
  column-gap: 9px;
  align-items: center;
  min-width: 178px;
  padding: 12px 14px;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  background: rgba(20,20,22,0.62);
  backdrop-filter: blur(18px);
  box-shadow: 0 16px 46px rgba(0,0,0,0.32);
}
.home-robot-chip strong {
  color: var(--text);
  font-family: var(--font-display);
  font-size: 13px;
  line-height: 1.1;
}
.home-robot-chip small {
  grid-column: 2;
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 10px;
  margin-top: 2px;
}
.chip-voice { left: 5%; top: 16%; }
.chip-chat { right: 1%; top: 34%; }
.chip-brain { left: 11%; bottom: 18%; }
.home-robot-caption {
  position: absolute;
  right: 7%;
  bottom: 11%;
  z-index: 3;
  display: grid;
  justify-items: end;
  gap: 4px;
}
.home-robot-caption small {
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.hero-team-label {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  padding-left: 8px;
}
.hero-employees { display: flex; flex-direction: column; gap: 12px; }
.emp-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px 18px;
  transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  cursor: pointer;
}
.emp-card:hover {
  border-color: var(--emp-color, var(--gold));
  transform: translateX(4px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.4);
}
.emp-icon-tile {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--emp-bg, var(--gold-dim));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.emp-card-content { flex: 1; min-width: 0; }
.emp-category { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2px; }
.emp-name { font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--text); }
