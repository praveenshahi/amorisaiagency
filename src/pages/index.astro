</style>
<script>
  const mount = document.getElementById('amorisHomeRobotCanvas');

  if (mount) {
    const THREE = await import('three');
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    camera.position.set(0, 0.12, 5.35);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: 'high-performance' });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.45));
    mount.appendChild(renderer.domElement);

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 760px)').matches;
    const segments = isMobile ? 28 : 48;

    scene.fog = new THREE.Fog(0x0c0c0e, 4, 14);
    scene.add(new THREE.AmbientLight(0xffffff, 0.35));

    const keyLight = new THREE.DirectionalLight(0xd4f0ff, 1.6);
    keyLight.position.set(2.5, 5, 4);
    keyLight.castShadow = true;
    scene.add(keyLight);

    const tealLight = new THREE.PointLight(0x00ffc6, 3.5, 5.5);
    tealLight.position.set(0, 1.25, 1.2);
    scene.add(tealLight);

    const goldLight = new THREE.PointLight(0xf0a824, 1.2, 5);
    goldLight.position.set(-1.8, -1.0, 1.5);
    scene.add(goldLight);

    const root = new THREE.Group();
    root.position.y = -0.7;
    scene.add(root);

    const bodyGroup = new THREE.Group();
    root.add(bodyGroup);

    const shellTexture = (() => {
      const size = 256;
      const canvas = document.createElement('canvas');
      canvas.width = size;
      canvas.height = size;
      const ctx = canvas.getContext('2d');
      if (ctx) {
        ctx.fillStyle = '#bdb9b1';
        ctx.fillRect(0, 0, size, size);
        for (let i = 0; i < 1800; i++) {
          ctx.globalAlpha = Math.random() > 0.2 ? 0.13 : 0.18;
          ctx.fillStyle = Math.random() > 0.2 ? '#1d1d1f' : '#ffffff';
          ctx.beginPath();
          ctx.arc(Math.random() * size, Math.random() * size, Math.random() * 1.4 + 0.35, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }
      const texture = new THREE.CanvasTexture(canvas);
      texture.wrapS = THREE.RepeatWrapping;
      texture.wrapT = THREE.RepeatWrapping;
      texture.repeat.set(4, 2);
      return texture;
    })();

    const shellMaterial = new THREE.MeshStandardMaterial({
      color: '#c8c3b8',
      map: shellTexture,
      roughness: 0.72,
      metalness: 0.18
    });

    const darkMaterial = new THREE.MeshStandardMaterial({
      color: '#101012',
      roughness: 0.55,
      metalness: 0.06
    });

    const glowMaterial = new THREE.MeshBasicMaterial({
      color: '#00ffc6',
      transparent: true,
      opacity: 0.16,
      blending: THREE.AdditiveBlending,
      depthWrite: false
    });

    const body = new THREE.Mesh(
      new THREE.SphereGeometry(0.82, segments, segments, 0, Math.PI * 2, Math.PI * 0.12, Math.PI * 0.72),
      shellMaterial
    );
    bodyGroup.add(body);

    const bodyRing = new THREE.Mesh(new THREE.TorusGeometry(0.44, 0.04, 18, segments), shellMaterial);
    bodyRing.position.y = 0.62;
    bodyRing.rotation.x = Math.PI / 2;
    bodyGroup.add(bodyRing);

    const neck = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.33, 0.22, segments), shellMaterial);
    neck.position.y = 0.74;
    bodyGroup.add(neck);

    const headGroup = new THREE.Group();
    headGroup.position.y = 1.18;
    bodyGroup.add(headGroup);

    const head = new THREE.Mesh(new THREE.SphereGeometry(0.52, segments, segments, 0, Math.PI * 2, 0, Math.PI), darkMaterial);
    headGroup.add(head);

    const glass = new THREE.Mesh(new THREE.SphereGeometry(0.535, segments, segments, 0, Math.PI * 2, 0, Math.PI), glowMaterial);
    headGroup.add(glass);

    const eyeMaterial = new THREE.MeshBasicMaterial({ color: '#f8fffb', toneMapped: false });
    const heartMaterial = new THREE.MeshBasicMaterial({ color: '#ff3366', toneMapped: false });
    const eyeMeshes = [];
    const heartMeshes = [];

    function makeEye(x) {
      const eyeGroup = new THREE.Group();
      eyeGroup.position.set(x, -0.04, 0.505);
      eyeGroup.rotation.y = x < 0 ? -0.15 : 0.15;

      const normalEye = new THREE.Mesh(new THREE.TorusGeometry(0.06, 0.006, 8, 24), eyeMaterial);
      normalEye.scale.y = 0.58;
      eyeGroup.add(normalEye);

      const heartShape = new THREE.Shape();
      heartShape.moveTo(0, -0.035);
      heartShape.bezierCurveTo(-0.07, -0.09, -0.12, -0.005, -0.06, 0.045);
      heartShape.bezierCurveTo(-0.03, 0.075, 0, 0.055, 0, 0.025);
      heartShape.bezierCurveTo(0, 0.055, 0.03, 0.075, 0.06, 0.045);
      heartShape.bezierCurveTo(0.12, -0.005, 0.07, -0.09, 0, -0.035);
      const heart = new THREE.Mesh(new THREE.ShapeGeometry(heartShape), heartMaterial);
      heart.visible = false;
      eyeGroup.add(heart);

      eyeMeshes.push(normalEye);
      heartMeshes.push(heart);
      headGroup.add(eyeGroup);
    }

    makeEye(-0.13);
    makeEye(0.13);

    function makeEar(x) {
      const direction = Math.sign(x);
      const ear = new THREE.Group();
      ear.position.set(x, 0.02, 0);

      const ring = new THREE.Mesh(new THREE.TorusGeometry(0.075, 0.018, 12, 28), shellMaterial);
      ring.rotation.y = Math.PI / 2;
      ear.add(ring);

      const cap = new THREE.Mesh(new THREE.CylinderGeometry(0.056, 0.056, 0.018, 20), shellMaterial);
      cap.rotation.z = Math.PI / 2;
      cap.position.x = direction * 0.015;
      ear.add(cap);

      const antenna = new THREE.Mesh(new THREE.CylinderGeometry(0.006, 0.006, 0.17, 8), shellMaterial);
      antenna.position.set(direction * 0.03, 0.12, 0);
      antenna.rotation.z = -direction * 0.18;
      ear.add(antenna);

      const dot = new THREE.Mesh(new THREE.SphereGeometry(0.017, 12, 12), new THREE.MeshBasicMaterial({ color: '#00ffc6', toneMapped: false }));
      dot.position.set(direction * 0.048, 0.205, 0);
      ear.add(dot);

      headGroup.add(ear);
    }

    makeEar(-0.54);
    makeEar(0.54);

    const shadow = new THREE.Mesh(
      new THREE.CircleGeometry(1.2, 40),
      new THREE.MeshBasicMaterial({ color: '#000000', transparent: true, opacity: 0.08 })
    );
    shadow.position.y = -0.88;
    shadow.rotation.x = -Math.PI / 2;
    shadow.scale.y = 0.28;
    root.add(shadow);

    const pointer = { x: 0, y: 0 };
    let lovedUntil = 0;
    let active = true;

    function updatePointer(clientX, clientY) {
      const rect = mount.getBoundingClientRect();
      pointer.x = ((clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -(((clientY - rect.top) / rect.height) * 2 - 1);
    }

    mount.addEventListener('pointermove', (event) => updatePointer(event.clientX, event.clientY), { passive: true });
    mount.addEventListener('pointerdown', (event) => {
      updatePointer(event.clientX, event.clientY);
      lovedUntil = performance.now() + 1700;
    });

    function resize() {
      const rect = mount.getBoundingClientRect();
      const width = Math.max(1, rect.width);
      const height = Math.max(1, rect.height);
      camera.aspect = width / height;
      camera.position.z = width < 520 ? 5.85 : 5.25;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height, false);
    }

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(mount);
    resize();

    document.addEventListener('visibilitychange', () => {
      active = document.visibilityState === 'visible';
    });

    let last = performance.now();
    function animate(now) {
      requestAnimationFrame(animate);
      if (!active) return;

      const delta = Math.min((now - last) / 1000, 0.08);
      last = now;
      const heartMode = now < lovedUntil;

      eyeMeshes.forEach((eye) => {
        eye.visible = !heartMode;
        if (!heartMode && !prefersReduced) {
          const blink = (now / 1000) % 3.1;
          eye.scale.y = blink < 0.15 ? Math.max(0.08, 0.58 - Math.sin((blink / 0.15) * Math.PI) * 0.5) : 0.58;
        }
      });
      heartMeshes.forEach((heart) => {
        heart.visible = heartMode;
        heart.scale.setScalar(heartMode ? 1 + Math.sin(now / 120) * 0.08 : 1);
      });

      const drift = prefersReduced ? 0 : Math.sin(now / 950) * 0.025;
      bodyGroup.rotation.y += ((-pointer.x * 0.34) - bodyGroup.rotation.y) * Math.min(1, delta * 7);
      bodyGroup.rotation.x += ((-pointer.y * 0.09 + drift) - bodyGroup.rotation.x) * Math.min(1, delta * 7);
      bodyGroup.rotation.z += ((-pointer.x * 0.07) - bodyGroup.rotation.z) * Math.min(1, delta * 7);
      headGroup.rotation.y += ((pointer.x * 0.68) - headGroup.rotation.y) * Math.min(1, delta * 10);
      headGroup.rotation.x += ((pointer.y * 0.2) - headGroup.rotation.x) * Math.min(1, delta * 10);
      root.position.x += ((pointer.x * 0.28) - root.position.x) * Math.min(1, delta * 3);

      renderer.render(scene, camera);
    }

    requestAnimationFrame(animate);
  }
</script>
