---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    category: 'Chat Employees',
    desc: 'Standalone chat and messaging agents with bounded scope.',
    employees: [
      { name: 'AI WhatsApp Assistant', href: '/ai-employees/chat/ai-whatsapp-assistant', price: '₹20k–50k', custom: false },
      { name: 'AI Support Assistant', href: '/ai-employees/chat/ai-support-assistant', price: '₹20k–50k', custom: false },
      { name: 'AI Lead Qualifier', href: '/ai-employees/chat/ai-lead-qualifier', price: '₹20k–50k', custom: false },
      { name: 'AI Social Responder', href: '/ai-employees/chat/ai-social-responder', price: '₹20k–50k', custom: false },
    ],
  },
  {
    category: 'Voice Employees',
    desc: 'AI voice agents for inbound and outbound calls. Price varies with language count, call volume, and integrations.',
    employees: [
      { name: 'AI Receptionist', href: '/ai-employees/voice/ai-receptionist', price: 'Custom', custom: true },
      { name: 'AI Booking Assistant', href: '/ai-employees/voice/ai-booking-assistant', price: 'Custom', custom: true },
      { name: 'AI Voice Sales Agent', href: '/ai-employees/voice/ai-voice-sales-agent', price: 'Custom', custom: true },
      { name: 'AI Collections Caller', href: '/ai-employees/voice/ai-collections-caller', price: 'Custom', custom: true },
    ],
  },
  {
    category: 'Knowledge Employees',
    desc: 'Scope depends on document volume, access control needs, and integrations. All knowledge employees are custom-priced.',
    employees: [
      { name: 'AI Company Brain', href: '/ai-employees/knowledge/ai-company-brain', price: 'Custom', custom: true },
      { name: 'AI Document Analyst', href: '/ai-employees/knowledge/ai-document-analyst', price: 'Custom', custom: true },
      { name: 'AI Help Desk', href: '/ai-employees/knowledge/ai-help-desk', price: 'Custom', custom: true },
      { name: 'AI Compliance Assistant', href: '/ai-employees/knowledge/ai-compliance-assistant', price: 'Custom', custom: true },
    ],
  },
  {
    category: 'Sales Employees',
    desc: 'Depends on CRM, data sources, and outreach volume. All are project-based with ongoing support.',
    employees: [
      { name: 'AI Prospector', href: '/ai-employees/sales/ai-prospector', price: 'Custom', custom: true },
      { name: 'AI Outreach Rep', href: '/ai-employees/sales/ai-outreach-rep', price: 'Custom', custom: true },
      { name: 'AI Sales Coordinator', href: '/ai-employees/sales/ai-sales-coordinator', price: 'Custom', custom: true },
    ],
  },
  {
    category: 'Operations Employees',
    desc: 'Scope varies with data sources, volume, and system integrations. Book a call for a quote.',
    employees: [
      { name: 'AI Business Analyst', href: '/ai-employees/operations/ai-business-analyst', price: 'Custom', custom: true },
      { name: 'AI Back-Office Clerk', href: '/ai-employees/operations/ai-back-office-clerk', price: 'Custom', custom: true },
      { name: 'AI Recruiter', href: '/ai-employees/operations/ai-recruiter', price: 'Custom', custom: true },
    ],
  },
];
---
<Base
  title="AI Employee Pricing — Transparent Ranges | Amoris"
  description="Pricing for all 18 Amoris AI employees. Chat agents start from ₹60k. Knowledge, Sales and Operations agents are custom-scoped. Book a demo for an exact number."
>

<section style="padding-bottom:40px;">
  <span class="section-eyebrow reveal">Pricing</span>
  <h1 class="reveal" style="margin-bottom:16px; max-width:20ch;">Transparent pricing.<br/>No surprises.</h1>
  <p class="reveal" style="max-width:52ch; font-size:1.05rem;">Simple agents have published ranges. Complex agents are scoped to your workflow — we give you a clear number on the demo call.</p>
</section>

<section style="padding-top:0; padding-bottom:60px;">
  <div class="pricing-note-grid reveal">
    <div class="pricing-note-item">
      <span style="font-size:24px;">📦</span>
      <div>
        <div style="font-family:var(--font-display); font-weight:700; margin-bottom:4px;">Setup fee</div>
        <p style="font-size:13px;">One-time build, training, integration, and testing. You own what we build.</p>
      </div>
    </div>
    <div class="pricing-note-item">
      <span style="font-size:24px;">🔄</span>
      <div>
        <div style="font-family:var(--font-display); font-weight:700; margin-bottom:4px;">Monthly support</div>
        <p style="font-size:13px;">Ongoing maintenance, updates, and improvements. Scoped per project.</p>
      </div>
    </div>
    <div class="pricing-note-item">
      <span style="font-size:24px;">💬</span>
      <div>
        <div style="font-family:var(--font-display); font-weight:700; margin-bottom:4px;">Custom builds</div>
        <p style="font-size:13px;">Clear number before you commit. Always. No "contact for pricing" black holes.</p>
      </div>
    </div>
  </div>
</section>

{tiers.map(tier => (
  <section style="border-top:1px solid var(--border); padding-top:56px; padding-bottom:56px;">
    <div style="margin-bottom:28px;">
      <h2 class="reveal" style="font-size:1.5rem; margin-bottom:6px;">{tier.category}</h2>
      <p class="reveal" style="font-size:14px; max-width:52ch;">{tier.desc}</p>
    </div>
    <div class="pricing-grid stagger-cards">
      {tier.employees.map(emp => (
        <a href={emp.href} class="pricing-card">
          <div class="pricing-card-name">{emp.name}</div>
          <div>
            {emp.custom ? (
              <span class="price-custom">Custom</span>
            ) : (
              <span class="price-range" style="font-size:1.2rem;">{emp.price}</span>
            )}
            {!emp.custom && <div class="price-note">setup · monthly support available</div>}
          </div>
          <span class="pricing-card-link">Details →</span>
        </a>
      ))}
    </div>
  </section>
))}

<section style="border-top:1px solid var(--border); padding-bottom:60px;">
  <div class="aios-pricing-card reveal">
    <span class="tag-gold" style="font-size:10px; letter-spacing:0.1em; text-transform:uppercase; font-family:var(--font-mono); display:inline-block; margin-bottom:20px;">Flagship</span>
    <h2 style="margin-bottom:8px;">Amoris AIOS — Hire the whole team.</h2>
    <p style="max-width:52ch; margin-bottom:28px;">All 18 AI employees, shared memory, cross-agent workflows, one command centre. Scoped per company size and workflow complexity.</p>
    <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
      <span class="price-custom">Custom pricing — contact us</span>
      <a href="/aios" class="btn btn-outline">Learn about AIOS →</a>
      <a href="/contact" class="btn btn-primary">Book a Free Audit →</a>
    </div>
  </div>
</section>

<section style="border-top:1px solid var(--border); text-align:center; position:relative; overflow:hidden;">
  <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:500px; height:200px; background:radial-gradient(ellipse, rgba(240,168,36,0.07) 0%, transparent 70%); pointer-events:none;"></div>
  <div style="position:relative; z-index:1;">
    <h2 class="reveal" style="margin-bottom:12px;">Get a clear price on the call.</h2>
    <p class="reveal" style="max-width:44ch; margin:0 auto 32px;">30 minutes. We scope the right employee for your problem and give you a number before we end the call.</p>
    <div class="reveal" style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
      <a href="/contact" class="btn btn-primary">Book a Free Audit →</a>
    </div>
  </div>
</section>

<style>
.pricing-note-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
@media (max-width:768px) { .pricing-note-grid { grid-template-columns:1fr; } }
.pricing-note-item { display:flex; gap:16px; align-items:flex-start; background:var(--bg-raised); border:1px solid var(--border); border-radius:var(--radius); padding:20px; }
.pricing-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
@media (max-width:900px) { .pricing-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:600px) { .pricing-grid { grid-template-columns:1fr; } }
.pricing-card { background:var(--bg-raised); border:1px solid var(--border); border-radius:var(--radius); padding:20px; display:flex; flex-direction:column; gap:12px; transition:all 0.22s; cursor:pointer; }
.pricing-card:hover { border-color:var(--border-bright); transform:translateY(-3px); box-shadow:0 16px 40px rgba(0,0,0,0.4); }
.pricing-card-name { font-family:var(--font-display); font-size:0.95rem; font-weight:700; color:var(--text); }
.pricing-card-link { font-size:12px; font-family:var(--font-mono); color:var(--text-muted); margin-top:auto; transition:color 0.2s; }
.pricing-card:hover .pricing-card-link { color:var(--gold); }
.aios-pricing-card { background:var(--bg-raised); border:1px solid rgba(240,168,36,0.2); border-radius:24px; padding:48px; }
@media (max-width:768px) { .aios-pricing-card { padding:32px 24px; } }
.tag-gold { color:var(--gold); background:var(--gold-dim); border:1px solid rgba(240,168,36,0.2); padding:4px 12px; border-radius:var(--radius-pill); }
</style>
</Base>
